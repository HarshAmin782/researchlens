cid)\n            for cid in top_ids]\n\nclass HybridRerankerRetriever(BaseRetriever):\n    @property\n    def strategy_name(self): return \"hybrid_rerank\"\n\n    def retrieve(self, query, top_k=5):\n        candidates = HybridRetriever().retrieve(query, top_k=20)\n        scores = reranker.predict([[query, c['text']] for c in candidates])\n        for c, s in zip(candidates, scores):\n            c['score'] = float(s)\n        return sorted(candidates, key=lambda x: x['score'], reverse=True)[:top_k]\n\nQUERY_SIGNALS = {\n    'consensus': ['do papers agree', 'do researchers agree', 'is there consensus',\n                  'controversy', 'debate', 'conflicting', 'disagree',\n                  'contradiction', 'contradictory', 'dispute'],\n    'comparative': ['compare', 'difference between', 'differ', 'versus', ' vs ',\n                    'better than', 'worse than', 'advantage', 'disadvantage',\n                    'trade-off', 'tradeoff', 'which is', 'contrast'],\n    'procedural': ['how to', 'how do i', 'steps to', 'implement', 'build',\n                   'create', 'set up', 'train', 'fine-tune', 'walkthrough'],\n    'factual': ['what is', 'what are', 'define', 'definition', 'explain',\n                'describe', 'who is', 'when was', 'where is', 'which paper']\n}\n\nQUERY_TO_STRATEGY = {\n    'factual': 'naive_rag',\n    'comparative': 'hybrid_rerank',\n    'consensus': 'hybrid_rag',\n    'procedural': 'semantic_rag'\n}\n\nSTRATEGY_TO_RETRIEVER = {\n    'naive_rag': NaiveRetriever(),\n    'semantic_rag': SemanticRetriever(),\n    'hybrid_rag': HybridRetriever(),\n    'hybrid_rerank': HybridRerankerRetriever()\n}\n\ndef keyword_classify(query):\n    q = query.lower()\n    for qtype, signals in QUERY_SIGNALS.items():\n        for signal in signals:\n            if signal in q:\n                return qtype, 0.95\n    return 'factual', 0.60\n\ndef route_query(query):\n    qtype, confidence = keyword_classify(query)\n    strategy = QUERY_TO_STRATEGY[qtype]\n    return {'query_type': qtype, 'strategy': strategy,\n            'confidence': confidence, 'retriever': STRATEGY_TO_RETRIEVER[strategy]}\n\nprint(\"Retriever and router classes defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-27T09:40:28.291126Z","iopub.execute_input":"2026-06-27T09:40:28.291543Z","iopub.status.idle":"2026-06-27T09:40:28.31203Z","shell.execute_reply.started":"2026-06-27T09:40:28.291515Z","shell.execute_reply":"2026-06-27T09:40:28.311146Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"model_name = \"mistralai/Mistral-7B-Instruct-v0.2\"\ntokenizer = AutoTokenizer.from_pretrained(model_name)\nllm = AutoModelForCausalLM.from_pretrained(\n    model_name,\n    torch_dtype=torch.float16,\n    device_map=\"auto\"\n)\ntokenizer.pad_token = tokenizer.eos_token\nprint(f\"Mistral loaded on: {next(llm.parameters()).device}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-27T09:40:28.313013Z","iopub.execute_input":"2026-06-27T09:40:28.314216Z","iopub.status.idle":"2026-06-27T09:41:49.712254Z","shell.execute_reply.started":"2026-06-27T09:40:28.31419Z","shell.execute_reply":"2026-06-27T09:41:49.711383Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def build_prompt(query: str, chunks: List[Dict]) -> str:\n    context = \"\\n\\n\".join([\n        f\"[Source: {c['title'][:60]}]\\n{c['text']}\"\n        for c in chunks\n    ])\n    return f\"\"\"[INST] You are a research assistant. Answer the question using ONLY the provided context.\nIf the context does not contain enough information to answer, say \"I don't have enough information in the loaded papers to answer this.\"\nBe concise and precise. Cite which paper your answer comes from.\n\nContext:\n{context}\n\nQuestion: {query} [/INST]\"\"\"\n\ndef generate_answer(query: str, chunks: List[Dict], max_new_tokens: int = 300) -> str:\n    prompt = build_prompt(query, chunks)\n    inputs = tokenizer(prompt, return_tensors=\"pt\", truncation=True,\n                       max_length=3500).to(llm.device)\n\n    with torch.no_grad():\n        outputs = llm.generate(\n            **inputs,\n            max_new_tokens=max_new_tokens,\n            temperature=0.3,\n            do_sample=True,\n            pad_token_id=tokenizer.eos_token_id\n        )\n\n    return tokenizer.decode(\n        outputs[0][inputs['input_ids'].shape[1]:],\n        skip_special_tokens=True\n    ).strip()\n\nprint(\"Generation function defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-27T09:41:49.713283Z","iopub.execute_input":"2026-06-27T09:41:49.713677Z","iopub.status.idle":"2026-06-27T09:41:49.7208Z","shell.execute_reply.started":"2026-06-27T09:41:49.713618Z","shell.execute_reply":"2026-06-27T09:41:49.719938Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def compute_uncertainty(query: str, chunks: List[Dict], answer: str) -> Dict:\n    retrieval_score = float(np.mean([c['score'] for c in chunks]))\n    retrieval_score = min(max(retrieval_score, 0.0), 1.0)\n\n    context_text = ' '.join([c['text'] for c in chunks])\n    context_words = set(re.sub(r'[^\\w\\s]', '', context_text.lower()).split())\n    answer_words = set(re.sub(r'[^\\w\\s]', '', answer.lower()).split())\n    stopwords = {'the', 'a', 'an', 'is', 'are', 'was', 'were', 'in', 'on',\n                 'at', 'to', 'for', 'of', 'and', 'or', 'but', 'it', 'this',\n                 'that', 'be', 'have', 'has', 'had', 'with', 'from', 'by'}\n    answer_content = answer_words - stopwords\n    if answer_content:\n        faithfulness = len(answer_content & context_words) / len(answer_content)\n    else:\n        faithfulness = 0.0\n\n    answer2 = generate_answer(query, chunks)\n    emb1 = embed_model.encode(answer, convert_to_tensor=True)\n    emb2 = embed_model.encode(answer2, convert_to_tensor=True)\n    consistency = float(torch.nn.functional.cosine_similarity(\n        emb1.unsqueeze(0), emb2.unsqueeze(0)\n    ).item())\n    consistency = min(max(consistency, 0.0), 1.0)\n\n    confidence = (retrieval_score * 0.4 + faithfulness * 0.3 + consistency * 0.3) * 100\n    confidence = round(min(max(confidence, 0.0), 100.0), 1)\n\n    if confidence >= 80:\n        badge = 'green'\n        action = 'answer'\n    elif confidence >= 50:\n        badge = 'yellow'\n        action = 'answer_with_caveat'\n    else:\n        badge = 'red'\n        action = 'refuse'\n\n    return {\n        'confidence': confidence,\n        'badge': badge,\n        'action': action,\n        'signals': {\n            'retrieval_score': round(retrieval_score, 3),\n            'faithfulness': round(faithfulness, 3),\n            'consistency': round(consistency, 3)\n        }\n    }\n\nprint(\"Uncertainty quantification defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-27T09:41:49.72163Z","iopub.execute_input":"2026-06-27T09:41:49.721969Z","iopub.status.idle":"2026-06-27T09:41:49.73798Z","shell.execute_reply.started":"2026-06-27T09:41:49.721947Z","shell.execute_reply":"2026-06-27T09:41:49.73723Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def answer_question(query: str, top_k: int = 5) -> Dict:\n    routing = route_query(query)\n    retriever = routing['retriever']\n    chunks = retriever.retrieve(query, top_k=top_k)\n\n    answer = generate_answer(query, chunks)\n    uncertainty = compute_uncertainty(query, chunks, answer)\n\n    if uncertainty['action'] == 'refuse':\n        final_answer = \"I don't have sufficient information in the loaded papers to answer this confidently.\"\n    elif uncertainty['action'] == 'answer_with_caveat':\n        final_answer = answer + \"\\n\\n⚠️ Note: Moderate confidence — verify this answer against the source papers.\"\n    else:\n        final_answer = answer\n\n    return {\n        'query': query,\n        'query_type': routing['query_type'],\n        'strategy': routing['strategy'],\n        'answer': final_a